#: src/sudo/cli/help.rs:3
msgid ""
"usage: sudo -h | -K | -k | -V\n"
"usage: sudo [-ABbknS] [-p prompt] [-D directory] [-g group] [-u user] [-i | "
"-s] [command [arg ...]]\n"
"usage: sudo -v [-ABknS] [-p prompt] [-g group] [-u user]\n"
"usage: sudo -l [-ABknS] [-p prompt] [-U user] [-g group] [-u user] [command "
"[arg ...]]\n"
"usage: sudo -e [-ABknS] [-p prompt] [-D directory] [-g group] [-u user] "
"file ..."
msgstr ""
"uso: sudo -h | -K | -k | -V\n"
"uso: sudo [-ABbknS] [-p solicitud] [-D directorio] [-g grupo] [-u usuario] [-i | "
"-s] [comando [argumento ...]]\n"
"uso: sudo -v [-ABknS] [-p solicitud] [-g grupo] [-u usuario]\n"
"uso: sudo -l [-ABknS] [-p solicitud] [-U usuario] [-g grupo] [-u usuario] [comando "
"[argumento ...]]\n"
"uso: sudo -e [-ABknS] [-p solicitud] [-D directorio] [-g grupo] [-u usuario] "
"archivo ..."

#: src/sudo/cli/help.rs:17
msgid ""
"Options:\n"
"  -A, --askpass                 use a helper program for password prompting\n"
"  -b, --background              run command in the background\n"
"  -B, --bell                    ring bell when prompting\n"
"  -D, --chdir=directory         change the working directory before running "
"command\n"
"  -e, --edit                    edit files instead of running a command\n"
"  -g, --group=group             run command as the specified group name or "
"ID\n"
"  -h, --help                    display help message and exit\n"
"  -i, --login                   run login shell as the target user; a "
"command may also be specified\n"
"  -K, --remove-timestamp        remove timestamp file completely\n"
"  -k, --reset-timestamp         invalidate timestamp file\n"
"  -l, --list                    list user's privileges or check a specific "
"command; use twice for longer format\n"
"  -n, --non-interactive         non-interactive mode, no prompts are used\n"
"  -p, --prompt=prompt           use the specified password prompt\n"
"  -S, --stdin                   read password from standard input\n"
"  -s, --shell                   run shell as the target user; a command may "
"also be specified\n"
"  -U, --other-user=user         in list mode, display privileges for user\n"
"  -u, --user=user               run command (or edit file) as specified user "
"name or ID\n"
"  -V, --version                 display version information and exit\n"
"  -v, --validate                update user's timestamp without running a "
"command\n"
"      --preserve-env=list       preserve specific environment variables\n"
"  --                            stop processing command line arguments"
msgstr ""
"Opciones:\n"
"  -A, --askpass                 usar un programa auxiliar para solicitar la contraseña\n"
"  -b, --background              ejecutar el comando en segundo plano\n"
"  -B, --bell                    emitir un sonido al solicitar la entrada\n"
"  -D, --chdir=directorio        cambiar el directorio de trabajo antes de "
"ejecutar el comando\n"
"  -e, --edit                    editar archivos en lugar de ejecutar un comando\n"
"  -g, --group=grupo             ejecutar el comando como el nombre o ID de\n"
"                                grupo especificado\n"
"  -h, --help                    mostrar el mensaje de ayuda y salir\n"
"  -i, --login                   ejecutar la shell de inicio de sesión como el usuario "
"objetivo; también se puede\n"
"                                especificar un comando\n"
"  -K, --remove-timestamp        eliminar completamente el archivo de marca de tiempo\n"
"  -k, --reset-timestamp         invalida el archivo de marca de tiempo\n"
"  -l, --list                    listar los privilegios del usuario o comprobar un comando\n"
"                                específico; usar dos veces para un formato extendido\n"
"  -n, --non-interactive         modo no interactivo, no se solicitan entradas\n"
"  -p, --prompt=solicitud        usar la solicitud de contraseña especificada\n"
"  -S, --stdin                   leer contraseña de la entrada estándar\n"
"  -s, --shell                   ejecutar la shell como el usuario objetivo; también "
"se puede especificar\n"
"                                un comando\n"
"  -U, --other-user=usuario      en modo lista, mostrar los privilegios del usuario\n"
"  -u, --user=usuario            ejecutar comando (o editar archivo) como el "
"nombre\n"
"                                o ID de usuario especificado\n"
"  -V, --version                 mostrar información de la versión y salir\n"
"  -v, --validate                actualizar la marca de tiempo del usuario sin ejecutar "
"un comando\n"
"      --preserve-env=lista      mantener las variables de entorno especificadas\n"
"  --                            dejar de procesar argumentos de la línea de comandos"

#: src/common/error.rs:74
msgid ""
"The \"no new privileges\" flag is set, which prevents sudo from running as "
"root.\n"
"If sudo is running in a container, you may need to adjust the container "
"configuration to disable the flag."
msgstr ""
"La opción «sin nuevos privilegios» está activada, lo que impide que se ejecute "
"como root.\n"
"Si sudo se está ejecutando en un contenedor, puede que necesites ajustar la "
"configuración del contenedor para desactivar la opción."

