module FindItem

use int.Int
use option.Option
use ref.Ref
use seq.Seq
use witness.Witness

(* model for a hashmap *)
type table 'id 'value

val function contains_key (t: table 'id 'value) (key: 'id): bool

val function get (t: table 'id 'value) (key: 'id): 'value
  requires { contains_key t key }

(* loose models for the types in sudoers::Ast *)

type name
type metavar 'a = All | Only 'a | Alias name
type qualified 'a = Allow 'a | Forbid 'a
type spec 'tag 'a = { inner: qualified (metavar 'a); info: 'tag }

type found_aliases = table name bool

predicate contains (pred: 'a -> bool) (a: seq 'a)
  = exists i. 0 <= i < length a /\ pred a[i]

function who (item: spec 'tag 'a): metavar 'a
  = match item.inner with
    | Allow x -> x
    | Forbid x -> x
    end

function condition (aliases: found_aliases) (item: spec 'tag 'a): option 'tag
  = match item with
    | { inner = Allow  (Alias name); info = tag } -> if get aliases name then Some tag else None
    | { inner = Forbid (Alias name); info = tag } -> if get aliases name then None else Some tag
    | { inner = Allow _;             info = tag } -> Some tag
    | _ -> None
    end

function matched_by (aliases: found_aliases) (pred: 'a -> bool) (item: spec 'tag 'a): bool
  = match who item with
    | All -> true
    | Only x -> pred x
    | Alias name -> contains_key aliases name
    end

let function bool_then (b: bool) (x: 'a): option 'a
  = if b then Some x else None

predicate is_final_match (pred: 'a -> bool) (a: seq 'a) (i: int)
  = 0 <= i < length a /\ pred a[i] /\ forall k. i < k < length a -> not pred a[k]

function final_match (pred: 'a -> bool) (items: seq 'a): 'a
  = items[witness (is_final_match pred items)]

(* Why3 model of the sudoers::find_item function *)
let find_item (items: seq (spec 'tag 'a)) (pred: 'a -> bool) (aliases: found_aliases): option 'tag
    ensures {
      let matched = matched_by aliases pred in
      let condition = condition aliases in
      match result with
      | Some tag -> contains matched items && condition (final_match matched items) = Some tag
      | None     -> contains matched items -> condition (final_match matched items) = None
      end
    }

= let ghost function matched = matched_by aliases pred in
  let ghost function condition (item: spec 'tag 'a) = condition aliases item in

  let result = ref None in

  for i = 0 to items.length - 1 do
    invariant { forall tag. !result = Some tag <->
                  exists j.  0 <= j < i /\ matched items[j] /\ Some tag = condition items[j] /\
                  forall k. j < k < i -> not matched items[k] }
    let (judgement, who) = match items[i].inner with
      | Forbid x -> (false, x)
      | Allow x -> (true, x)
    end in
    let info = items[i].info in
    match who with
      | All -> result := judgement.bool_then(info)
      | Only id -> if pred id then result := judgement.bool_then(info)
      | Alias name -> if aliases.contains_key name then
          result := if aliases.get name then
             judgement.bool_then(info)
          else
             (not judgement).bool_then(info)
    end;
  done;

  (* perform a "virtual loop" to strength the case !result = None;
     this could also be solved by adding a ghost variable above *)
  ghost if is_none !result && contains matched items then
    for i = items.length - 1 downto 0 do
      invariant { forall k. i < k < items.length -> not matched items[k] }
      invariant { exists k. 0 <= k <= i /\ matched items[k] }
      if matched items[i] then begin
        assert { condition (final_match matched items) = None };
        break;
      end;
    done;

  !result;

end

module AliasTable

use int.Int
use option.Option
use ref.Ref
use seq.Seq
use fmap.Fmap

let function fmap_contains_key (t: fmap 'id 'v) (k: 'id): bool
  = any bool ensures { result = Fmap.mem k t }

let function fmap_get (t: fmap 'id 'v) (k: 'id): 'v
  = any 'v ensures { result = Fmap.find k t }

clone export FindItem
 with type table = fmap, val contains_key = fmap_contains_key, val get = fmap_get

clone fmap.MapImp as H
 with type key = name

type mut_found_aliases = H.t bool

(* this is essentially a coercion *)
let unmut (t: mut_found_aliases): found_aliases
= any found_aliases ensures { result = t }

(* Model of some AST types and Rust types *)
type def 'a = (name, seq (spec () 'a))

let predicate is_some (x: option 'a) = not is_none x

(* Why3 translation of get_aliases *)

let lemma prepending_doesnt_change_match (x: spec () 'a) (set: found_aliases) (pred: 'a -> bool) (specs: seq (spec () 'a))
  requires { contains (matched_by set pred) specs }
  ensures { final_match (matched_by set pred) specs = final_match (matched_by set pred) (cons x specs) }
= for j = 0 to length specs - 1 do
    invariant { exists i. j <= i < length specs /\ matched_by set pred specs[i] }
    if matched_by set pred specs[j] && pure { forall k. j < k < length specs -> not matched_by set pred specs[k] } then
      begin
        assert { specs[j] = (cons x specs)[j+1] };
        assert { final_match (matched_by set pred) specs = specs[j] };
        let modded_specs = cons x specs in
        assert { final_match (matched_by set pred) modded_specs = specs[j] };
        break
      end;
   done

let lemma final_match_exists (pred: 'a -> bool) (a: seq 'a)
  requires { exists i. 0 <= i < length a /\ pred a[i] }
  ensures { exists j. is_final_match pred a j }
= for k = 0 to a.length - 1 do
    invariant { exists i. k <= i < length a /\ pred a[i] }
    if pure { forall j. k < j < length a -> not pred a[j] } then break
  done

let get_aliases (table: seq (def 'a)) (pred: 'a -> bool): found_aliases
  (* make sure the keys are uniquely defined *)
  requires { forall i j. 0 <= i < j < length table ->
               let (k1, _) = table[i] in
               let (k2, _) = table[j] in
               k1 <> k2 }

  (* make sure the table is topologically sorted *)
  requires { forall i j. 0 <= i <= j < length table ->
               let (_, items) = table[i] in
               let (key, _) = table[j] in
               forall k. 0 <= k < length items -> who items[k] <> Alias key }

  (* the resulting table encodes the membership of an identifier in an alias and its status *)
  ensures { let matched = matched_by result pred in
            forall i. 0 <= i < length table -> let (id, specs) = table[i] in
              H.mem id result <-> contains matched specs }

  ensures { let matched = matched_by result pred in
            forall i. 0 <= i < length table -> let (id, specs) = table[i] in
              H.mem id result -> H.find id result <-> condition result (final_match matched specs) = Some () }

= let all = { inner=Allow All; info=() } in

  let set = ref (H.create ()) in

  for i = 0 to table.length - 1 do
    invariant { forall j. i <= j < table.length -> let (key, _) = table[j] in
                  not H.mem key !set }
    invariant { forall j. 0 <= j < i -> let (id, specs) = table[j] in
                  H.mem id !set <-> contains (matched_by !set pred) specs }
    invariant { forall j. 0 <= j < i -> let (id, specs) = table[j] in
                  H.mem id !set -> H.find id !set <-> condition !set (final_match (matched_by !set pred) specs) = Some () }

      let (id, specs) = table[i] in
      label Loop in
      if is_some (find_item specs pred (unmut !set)) then
        begin
          assert { forall k. 0 <= k < length specs -> who specs[k] <> Alias id };

          H.add id true !set;

          assert { final_match (matched_by (!set at Loop) pred) specs = final_match (matched_by !set pred) specs
             by forall p q: int -> bool. (forall x. p x <-> q x) -> p = q
          };
          assert { condition (!set at Loop) (final_match (matched_by !set pred) specs) = Some () };
        end
      else if is_none (find_item (cons all specs) pred (unmut !set)) then
        begin
          assert { exists i. matched_by !set pred specs[i] };

          H.add id false !set;
        end;
  done;

  unmut !set

end

module Expansion

use int.Int
use option.Option
use ref.Ref
use seq.Seq

use AliasTable

let function seqmap (f: 'a -> 'b) (items: seq 'a): seq 'b
  ensures { length result = length items }
  ensures { forall i. 0 <= i < length result -> result[i] = f items[i] }
= let result = ref empty in
  for i = 0 to length items - 1 do
    invariant { length !result = i }
    invariant { forall j. 0 <= j < i -> (!result)[j] = f items[j] }
    result := snoc !result (f items[i])
  done;
  !result

(* now for the important proof: our alias expansion algorithm is the same as actual expansion; this function
   is not present in the Rust code base *)

let expand_aliases (items: seq (spec 'tag 'a)) (table: seq (def 'a)) (ghost pred: 'a -> bool) (ghost aliases: found_aliases): seq (spec 'tag 'a)
  (* require all aliases to be defined in the table *)
  requires { forall i. 0 <= i < length items ->
               forall key. who items[i] = Alias key ->
                 exists j. 0 <= j < length table /\ let (id, _) = table[j] in id = key }

  (* provenance: this function does not introduce any information outside that given to it; and aliases appear from referenced table rows only *)
  ensures { forall i. 0 <= i < length result ->
              (exists k j. 0 <= k < length table /\ let (id, def) = table[k] in 0 <= j < length def /\ who result[i] = who def[j] /\
                 exists n. 0 <= n < length items /\ who items[n] = Alias id) \/
              (exists j. 0 <= j < length items /\ who result[i] = who items[j] /\
                 forall key. who result[i] <> Alias key) }

  (* the alias table encodes the membership of an identifier in an alias and its status;
     i.e. it has been produced by get_aliases above *)
  requires { let matched = matched_by aliases pred in
             let condition = condition aliases in
             forall i. 0 <= i < length table -> let (id, specs) = table[i] in
               (H.mem id aliases <-> contains matched specs) /\
               (H.mem id aliases -> H.find id aliases <-> condition (final_match matched specs) = Some ()) }

  ensures {
        let matched = matched_by aliases pred in
        let condition = condition aliases in
        if contains matched result then
          contains matched items /\ condition (final_match matched result) = condition (final_match matched items)
        else
          not contains matched items
  }

= let function negated (qual: qualified (metavar 'a)): qualified (metavar 'a) =
    match qual with
    | Allow x -> Forbid x
    | Forbid x -> Allow x
    end
  in

  let function find_def (key: name): seq (spec () 'a)
    requires { exists i. 0 <= i < length table /\ let (id, _) = table[i] in id = key }
    ensures { exists i. 0 <= i < length table /\ (key, result) = table[i] }
  = for i = 0 to length table - 1 do
      invariant { forall j. 0 <= j < i -> let (id, _) = table[j] in id <> key }
      let (id, def) = table[i] in
      if any bool ensures { result <-> id = key } then return def
    done;
    absurd
  in

  let distribute tag = seqmap (fun spec -> { spec with info = tag }) in
  let negate = seqmap (fun spec -> { spec with inner = negated spec.inner }) in

  let expanded = ref empty in
  for i = 0 to length items - 1 do
    invariant { forall i. 0 <= i < length !expanded ->
                    (exists k j. 0 <= k < length table /\ let (id, def) = table[k] in 0 <= j < length def /\ who (!expanded)[i] = who def[j] /\
                      exists n. 0 <= n < length items /\ who items[n] = Alias id) \/
                    (exists j. 0 <= j < length items /\ who (!expanded)[i] = who items[j] /\
                      forall key. who (!expanded)[i] <> Alias key) }

    invariant {
        let matched = matched_by aliases pred in
        let condition = condition aliases in
        if contains matched !expanded then
          contains matched items[0..i] /\ condition (final_match matched !expanded) = condition (final_match matched items[0..i])
        else
          not contains matched items[0..i]
    }

    label Loop in
    assert { forall x y, p: spec 'tag 'a -> bool. contains p x -> contains p (x++y) };

    match items[i] with
    | { inner = Allow(Alias key); info = tag } ->
       let expansion = find_def key in
       expanded := !expanded ++ distribute tag expansion;

       assert {
         let matched = matched_by aliases pred in
         matched items[i] ->
         condition aliases (final_match matched !expanded) = condition aliases (final_match matched items[0..i+1])
           by final_match matched !expanded = { (final_match (matched_by aliases pred) expansion) with info = tag }
           /\ (condition aliases (final_match (matched_by aliases pred) expansion) = Some () <-> H.find key aliases)
           /\ (final_match matched items[0..i+1] = items[i] by items[0..i+1] = snoc items[0..i] items[i])
       };

       assert { forall i. 0 <= i < length (!expanded at Loop) -> (!expanded)[i] = (!expanded at Loop)[i] };

    | { inner = Forbid(Alias key); info = tag } ->
       let expansion = negate (find_def key) in
       expanded := !expanded ++ distribute tag expansion;

       assert { forall x. who { inner = x; info = () } = who { inner = negated x; info = () } };
       assert { matched_by aliases pred items[i] -> contains (matched_by aliases pred) !expanded };

       assert {
         let matched = matched_by aliases pred in
         matched items[i] ->
         condition aliases (final_match matched !expanded) = condition aliases (final_match matched items[0..i+1])
           by final_match matched !expanded = { (final_match (matched_by aliases pred) expansion) with info = tag }
           /\ ((condition aliases (final_match (matched_by aliases pred) expansion) = None <-> H.find key aliases)
               by forall i. 0 <= i < length (find_def key) -> matched_by aliases pred (find_def key)[i] ->
                    condition aliases expansion[i] = None <-> condition aliases (find_def key)[i] = Some ())
           /\ (final_match matched items[0..i+1] = items[i] by items[0..i+1] = snoc items[0..i] items[i])
       };

       assert { forall i. 0 <= i < length (!expanded at Loop) -> (!expanded)[i] = (!expanded at Loop)[i] };

    | _other ->
       expanded := snoc !expanded items[i];
    end;
    assert { items[0..i+1] = snoc items[0..i] items[i] };
  done;
  assert { items[0.. length items] = items };
  !expanded

predicate weak_permut_all (x y: seq 'a)
  = length x = length y /\
    (forall i. 0 <= i < length x -> exists j. 0 <= j < length y /\ x[i] = y[j]) /\
    (forall i. 0 <= i < length y -> exists j. 0 <= j < length x /\ x[j] = y[i])

let expand_all_aliases (items: seq (spec 'tag 'a)) (table: seq (def 'a)) (ghost pred: 'a -> bool) (ghost aliases: found_aliases) (ghost sorted_table: seq (def 'a)): seq (spec 'tag 'a)
  (* make sure the keys are uniquely defined *)
  requires { forall i j. 0 <= i < j < length table ->
               let (k1, _) = table[i] in
               let (k2, _) = table[j] in
               k1 <> k2 }

  (* require all aliases to be defined in the table *)
  requires { forall i. 0 <= i < length items ->
               forall key. who items[i] = Alias key ->
                 exists j. 0 <= j < length table /\ let (id, _) = table[j] in id = key }

  (* this function also requires that it is grounded *)
  requires { forall i. 0 <= i < length table ->
               let (_, items) = table[i] in
               forall k, key. 0 <= k < length items -> who items[k] = Alias key ->
               exists j. 0 <= j < length table /\ let (id, _) = table[j] in id = key }

  (* require that the table can be topologically sorted; otherwise a full expansion is impossible *)
  requires { forall i j. 0 <= i <= j < length sorted_table ->
               let (_, items) = sorted_table[i] in
               let (key, _) = sorted_table[j] in
               forall k. 0 <= k < length items -> who items[k] <> Alias key }

  requires { weak_permut_all table sorted_table }

  (* the alias table encodes the membership of an identifier in an alias and its status;
     i.e. it has been produced by get_aliases above *)
  requires { let matched = matched_by aliases pred in
             let condition = condition aliases in
             forall i. 0 <= i < length table -> let (id, specs) = table[i] in
               (H.mem id aliases <-> contains matched specs) /\
               (H.mem id aliases -> H.find id aliases <-> condition (final_match matched specs) = Some ()) }

  (* the result is fully expanded *)
  ensures { not exists i, key. 0 <= i < length result /\ who result[i] = Alias key }

  (* the primary result *)
  ensures {
        let matched = matched_by aliases pred in
        let condition = condition aliases in
        if contains matched result then
          contains matched items /\ condition (final_match matched result) = condition (final_match matched items)
        else
          not contains matched items
  }

= let cur = ref items in
  for iter = 1 to table.length do
    invariant {
        let matched = matched_by aliases pred in
        let condition = condition aliases in
        if contains matched !cur then
          contains matched items /\ condition (final_match matched !cur) = condition (final_match matched items)
        else
          not contains matched items
    }

    invariant { forall i. 0 <= i < length !cur ->
                  forall key. who (!cur)[i] = Alias key ->
                    exists j. 0 <= j <= length table - iter /\ let (id, _) = sorted_table[j] in id = key }

    cur := expand_aliases !cur table pred aliases;
  done;
  !cur

end

module Correctness

use int.Int
use option.Option
use ref.Ref
use seq.Seq

use FindItem
use AliasTable
use Expansion

let lemma permut_preserves_uniqueness (tab1 tab2: seq 'a) (i j: int)
  requires { weak_permut_all tab1 tab2 }
  requires { 0 <= i < j < length tab1 }
  requires { tab1[i] = tab1[j] }
  requires { forall i j. 0 <= i < j < length tab2 -> tab2[i] <> tab2[j] }
  ensures { false }
= let tab = ref tab1 in
  for i = 0 to length tab1 - 1 do
    invariant { weak_permut_all !tab tab2 }
    invariant { exists i j. 0 <= i < j < length !tab /\ (!tab)[i] = (!tab)[j] }
    invariant { forall j. 0 <= j < i -> (!tab)[j] = tab2[j] }
    let j = any int ensures { i <= result < length tab2 /\ tab2[i] = (!tab)[result] } in
    tab := (!tab)[i <- !(tab)[j]][j <- (!tab)[i]];
  done

let demonstration (items: seq (spec 'tag 'a)) (table: seq (def 'a)) (pred: 'a -> bool) (sorted_table: seq (def 'a))
  (* make sure the keys are uniquely defined *)
  requires { forall i j. 0 <= i < j < length table ->
               let (k1, _) = table[i] in
               let (k2, _) = table[j] in
               k1 <> k2 }

  (* require all aliases to be defined in the table *)
  requires { forall key.
               (exists i. 0 <= i < length items /\ who items[i] = Alias key) \/
               (exists k i. 0 <= k < length table /\ let (_, items) = table[k] in
                            0 <= i < length items /\ who items[i] = Alias key)
               ->
                 exists j. 0 <= j < length table /\ let (id, _) = table[j] in id = key }

  (* make sure the table can be topologically sorted *)
  requires { weak_permut_all sorted_table table }

  requires { forall i j. 0 <= i <= j < length sorted_table ->
               let (_, items) = sorted_table[i] in
               let (key, _) = sorted_table[j] in
               forall k. 0 <= k < length items -> who items[k] <> Alias key }

= let aliases = get_aliases sorted_table pred in

  let expanded = expand_all_aliases items table (ghost pred) (ghost aliases) (ghost sorted_table) in

  let a = find_item expanded pred (any found_aliases) in
  let b = find_item items pred aliases in

  assert { a = b }

end
